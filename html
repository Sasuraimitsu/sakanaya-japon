<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SAKANAYA JAPON - 春の訪れ メッセージカード</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;700;900&display=swap" rel="stylesheet">
    
    <!-- Chosen Palette: Navy & Crimson (Traditional Japanese Palette) -->
    <!-- Application Structure Plan: A clean, interactive single-page app designed to act as a digital companion to the physical fish box. It uses a tabbed structure (Message vs. Menu) to avoid information overload. Rationale: Users want to read the heartfelt message first, then explore the ingredients. -->
    <!-- Visualization & Content Choices: Box Contents -> Composition -> Doughnut Chart (Chart.js) -> Shows the balance of the selection. Shipping Schedule -> Information -> Grid Layout -> Provides clarity on delivery. -->
    <!-- CONFIRMATION: NO SVG graphics used. NO Mermaid JS used. -->

    <style>
        body {
            font-family: 'Noto Serif JP', serif;
            background-color: #fdfcf8;
            color: #1e293b;
        }
        .chart-container {
            position: relative;
            width: 100%;
            max-width: 500px;
            margin-left: auto;
            margin-right: auto;
            height: 300px;
            max-height: 400px;
        }
        .fade-in { animation: fadeIn 0.8s ease-out forwards; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .tab-active {
            border-bottom: 3px solid #e63946;
            color: #1a4472;
            font-weight: bold;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <!-- Header Section -->
    <header class="bg-[#1a4472] text-white py-8 px-4 text-center shadow-lg">
        <div class="max-w-4xl mx-auto">
            <h1 class="text-3xl sm:text-4xl font-bold tracking-[0.4em] mb-2">SAKANAYA JAPON</h1>
            <p class="text-xs sm:text-sm tracking-[0.2em] opacity-80 uppercase font-sans">Premium Seafood Selection & Global Export</p>
        </div>
    </header>

    <!-- Navigation Tabs -->
    <nav class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm">
        <div class="max-w-4xl mx-auto flex">
            <button onclick="switchTab('message')" id="tab-message" class="flex-1 py-4 text-sm sm:text-base tracking-widest tab-active transition-all">店主の想い</button>
            <button onclick="switchTab('menu')" id="tab-menu" class="flex-1 py-4 text-sm sm:text-base tracking-widest text-slate-500 hover:bg-slate-50 transition-all">本日のお品書き</button>
            <button onclick="switchTab('info')" id="tab-info" class="flex-1 py-4 text-sm sm:text-base tracking-widest text-slate-500 hover:bg-slate-50 transition-all">配送・店舗情報</button>
        </div>
    </nav>

    <main class="flex-grow max-w-4xl mx-auto w-full p-6 sm:p-12">
        
        <!-- Section: Message (Front) -->
        <section id="section-message" class="fade-in space-y-10">
            <div class="text-center mb-12">
                <h2 class="text-2xl sm:text-3xl font-bold text-[#1a4472] mb-6">海を越える鮮度を、日本の食卓へ。</h2>
                <div class="w-12 h-1 bg-[#e63946] mx-auto"></div>
            </div>
            
            <div class="bg-white p-8 sm:p-12 rounded-lg shadow-sm border border-slate-100 leading-[2.2] tracking-widest text-lg text-justify space-y-6">
                <p class="font-bold text-xl">SAKANAYA JAPON 店主です。</p>
                <p>この度は、数あるお店の中から当店のお魚をお選びいただき、誠にありがとうございます。</p>
                <p>近年、お魚の価格が高騰し、食卓から少しずつ遠い存在になってしまったように感じます。「もっと身近に、最高に美味しい旬を味わってほしい」——その一心で、私たちは独自のルートを開拓し、この一箱を準備しました。</p>
                <p>かつて当たり前だった「旬を祝う食卓」が、今日この日から、お客様の日常の中でまた鮮やかに復活することを願って。</p>
                <p class="text-[#e63946] font-bold text-center py-4">心を込めてお届けいたします。どうぞ、春の息吹をお楽しみください。</p>
                <div class="text-right pt-6">
                    <span class="border-b-2 border-[#1a4472] pb-1 text-2xl font-black italic">SAKANAYA JAPON 店主より</span>
                </div>
            </div>
        </section>

        <!-- Section: Menu (Back) -->
        <section id="section-menu" class="hidden fade-in space-y-8">
            <div class="flex flex-col md:flex-row gap-8 items-start">
                <div class="flex-1 w-full">
                    <h3 class="text-xl font-bold text-[#1a4472] mb-6 border-l-4 border-[#e63946] pl-4">本日の店主おすすめ：テーマ「春の訪れ」</h3>
                    
                    <div class="space-y-6">
                        <div class="bg-white p-6 rounded-lg border border-slate-100 hover:shadow-md transition-shadow">
                            <div class="flex justify-between items-center mb-2">
                                <span class="text-lg font-bold">● 真鰯（いわし）</span>
                                <span class="text-[10px] bg-[#1a4472] text-white px-2 py-1 rounded">宮城県産</span>
                            </div>
                            <p class="text-sm text-slate-600 leading-relaxed">三陸の冷たい海で身が締まった、今が盛りの鰯です。脂の乗りが非常に良く、お刺身や塩焼きでその甘みをご堪能ください。</p>
                        </div>

                        <div class="bg-white p-6 rounded-lg border border-slate-100 hover:shadow-md transition-shadow">
                            <div class="flex justify-between items-center mb-2">
                                <span class="text-lg font-bold">● メカブ</span>
                                <span class="text-[10px] bg-[#1a4472] text-white px-2 py-1 rounded">宮城県産</span>
                            </div>
                            <p class="text-sm text-slate-600 leading-relaxed">春を告げる三陸の宝石。サッと湯通しして鮮やかな緑色に変わる姿と、磯の香り、コリコリの食感をお楽しみください。</p>
                        </div>

                        <div class="bg-white p-6 rounded-lg border border-slate-100 hover:shadow-md transition-shadow">
                            <div class="flex justify-between items-center mb-2">
                                <span class="text-lg font-bold">● 蛍烏賊（ほたるいか）</span>
                                <span class="text-[10px] bg-[#1a4472] text-white px-2 py-1 rounded">兵庫県産</span>
                            </div>
                            <p class="text-sm text-slate-600 leading-relaxed">日本海の春の使者。冷凍で旨みを凝縮しています。そのまま、あるいはサッと炙って濃厚なワタのコクをどうぞ。</p>
                        </div>
                    </div>
                </div>

                <div class="w-full md:w-80 space-y-6">
                    <div class="bg-[#1a4472] text-white p-6 rounded-lg">
                        <h4 class="font-bold mb-4 flex items-center gap-2">
                            <span>✨</span> 店主の特別セレクション
                        </h4>
                        <div class="space-y-4 text-sm">
                            <div class="border-b border-white/20 pb-2">
                                <p class="font-bold text-[#facc15]">国産アワビ（300gサイズ）</p>
                                <p class="opacity-80">煮付けに最適な肉厚サイズを厳選。</p>
                            </div>
                            <div>
                                <p class="font-bold text-[#facc15]">アラスカ産 鱈白子</p>
                                <p class="opacity-80">クリーミーで濃厚なコクを天ぷらで。</p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="bg-white p-4 rounded-lg border border-slate-200">
                        <p class="text-xs font-bold text-center text-slate-400 mb-3 uppercase tracking-widest">Box Balance</p>
                        <div class="chart-container">
                            <canvas id="menuChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section: Info -->
        <section id="section-info" class="hidden fade-in space-y-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="bg-white p-8 rounded-lg border border-slate-100 shadow-sm">
                    <h3 class="text-xl font-bold text-[#1a4472] mb-6 flex items-center gap-2">
                        <span>🚚</span> サービス・配送案内
                    </h3>
                    <ul class="space-y-4 text-slate-700">
                        <li class="flex justify-between border-b border-slate-100 pb-2">
                            <span class="font-bold">仕入日</span>
                            <span>毎週 月・木曜日</span>
                        </li>
                        <li class="flex justify-between border-b border-slate-100 pb-2">
                            <span class="font-bold">発送日</span>
                            <span>毎週 月・木曜日</span>
                        </li>
                        <li class="pt-4 text-sm leading-relaxed text-slate-500">
                            ※鮮度を最優先するため、仕入れたその日に発送いたします。天候等により内容が変更となる場合がございます。
                        </li>
                    </ul>
                </div>

                <div class="bg-white p-8 rounded-lg border border-slate-100 shadow-sm text-center">
                    <h3 class="text-xl font-bold text-[#1a4472] mb-6">公式Instagram</h3>
                    <div class="w-32 h-32 bg-slate-100 mx-auto mb-4 flex items-center justify-center border-2 border-dashed border-slate-300">
                        <p class="text-[10px] text-slate-400 font-sans px-2">QRコードをここに配置予定</p>
                    </div>
                    <p class="text-[#1a4472] font-bold mb-2">@sakanaya_japon</p>
                    <p class="text-xs text-slate-500 italic">最新の入荷情報や、店主のおすすめレシピを更新中！</p>
                </div>
            </div>
        </section>

    </main>

    <!-- Footer -->
    <footer class="bg-slate-900 text-white/50 py-12 px-4 text-center text-xs tracking-widest">
        <p class="mb-2">SAKANAYA JAPON SELECTION</p>
        <p>&copy; 2026 SAKANAYA JAPON. All Rights Reserved.</p>
    </footer>

    <script>
        // Tab switching logic
        function switchTab(tabName) {
            const sections = ['message', 'menu', 'info'];
            sections.forEach(s => {
                document.getElementById(`section-${s}`).classList.add('hidden');
                document.getElementById(`tab-${s}`).classList.remove('tab-active');
                document.getElementById(`tab-${s}`).classList.add('text-slate-500');
            });

            document.getElementById(`section-${tabName}`).classList.remove('hidden');
            document.getElementById(`tab-${tabName}`).classList.add('tab-active');
            document.getElementById(`tab-${tabName}`).classList.remove('text-slate-500');

            if(tabName === 'menu') initChart();
        }

        // Chart.js implementation for Menu Balance
        let chartInstance = null;
        function initChart() {
            const ctx = document.getElementById('menuChart').getContext('2d');
            if (chartInstance) chartInstance.destroy();
            
            chartInstance = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['鮮魚(いわし等)', '海藻(メカブ等)', '加工(蛍烏賊等)', '高級食材(アワビ等)'],
                    datasets: [{
                        data: [40, 20, 20, 20],
                        backgroundColor: ['#1a4472', '#10b981', '#f59e0b', '#e63946'],
                        borderWidth: 0,
                        hoverOffset: 10
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                boxWidth: 12,
                                font: { size: 10, family: 'sans-serif' }
                            }
                        }
                    }
                }
            });
        }
    </script>
</body>
</html>
